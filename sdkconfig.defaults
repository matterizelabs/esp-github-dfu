CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_TWO_OTA_LARGE=y

CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y
CONFIG_MBEDTLS_TLS_CLIENT_ONLY=y

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_MAIN_TASK_AFFINITY_CPU0=y
CONFIG_ESP_TASK_WDT_INIT=n
CONFIG_BOOTLOADER_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

CONFIG_ESP_GH_OTA_BUF_SIZE=1024
CONFIG_ESP_GH_OTA_RECV_TIMEOUT=30000

# Optional API key for /api/config endpoint (X-API-Key header).
# Leave empty for no auth.
# CONFIG_ESP_GH_OTA_API_KEY=""

# Resume an interrupted OTA across reboots (partial Range download + NVS checkpoint)
CONFIG_ESP_GH_OTA_ENABLE_PARTIAL_DOWNLOAD=y
CONFIG_ESP_GH_OTA_ENABLE_RESUMPTION=y

# Anti-rollback: reject firmware whose secure_version is below the eFuse value.
# WARNING: enabling this burns eFuses one-way. Do not enable on a dev device
# unless you manage secure_version bumping per release.
CONFIG_BOOTLOADER_APP_ANTI_ROLLBACK=y
